    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "auto-changelog": "^2.5.1",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  }
}
