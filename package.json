{
  "name": "eslint-plugin-tailwindcss-order",
  "version": "2.2.0",
  "description": "An eslint plugin to sort Tailwind CSS classes with a custom order",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dherault/eslint-plugin-tailwindcss-order.git"
  },
  "bugs": {
    "url": "https://github.com/dherault/eslint-plugin-tailwindcss-order/issues"
  },
  "homepage": "https://github.com/dherault/eslint-plugin-tailwindcss-order",
  "keywords": [
    "eslint",
    "eslint plugin",
    "tailwind",
    "tailwindcss",
    "css",
    "style",
    "lint",
    "linting",
    "sort",
    "order",
    "classes"
  ],
  "author": "David Hérault <dherault@gmail.com> (https://github.com/dherault)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
